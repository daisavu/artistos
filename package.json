{\n  \"name\": \"artistos\",\n  \"version\": \"0.1.0\",\n  \"description\": \"ArtistOS - AI-powered independent artist operating system\",\n  \"private\": true,\n  \"workspaces\": [\n    \"backend\",\n    \"frontend\"\n  ],\n  \"scripts\": {\n    \"install-all\": \"npm install && npm install --workspace=backend && npm install --workspace=frontend\",\n    \"dev\": \"docker-compose up\",\n    \"dev:backend\": \"npm run dev --workspace=backend\",\n    \"dev:frontend\": \"npm run dev --workspace=frontend\",\n    \"test\": \"npm test --workspace=backend && npm test --workspace=frontend\",\n    \"lint\": \"npm run lint --workspace=backend && npm run lint --workspace=frontend\"\n  },\n  \"keywords\": [\n    \"music\",\n    \"artist\",\n    \"distribution\",\n    \"analytics\",\n    \"ai\"\n  ],\n  \"author\": \"ArtistOS Team\",\n  \"license\": \"MIT\"\n}